# Paths are resolved from repo root when using autoresearch-switch
UPSTREAMS_DIR=./upstreams
RUNS_DIR=./runs
WORK_DIR=./work
SECRETS_DIR=./secrets

# Upstream repositories
REPO_KARPATHY_URL=https://github.com/karpathy/autoresearch.git
REPO_DGX_URL=https://github.com/David-Barnes-Data-Imaginations/autoresearch-DGX-Spark.git
REPO_NAUTO_URL=https://github.com/iii-experimental/n-autoresearch.git
REPO_GEMINI_URL=https://github.com/supratikpm/gemini-autoresearch.git
REPO_AUTOKERNEL_URL=https://github.com/RightNow-AI/autokernel.git

# Resource defaults
KARPATHY_MEM_LIMIT=60g
KARPATHY_MEM_RESERVATION=45g
KARPATHY_TRAIN_TIMEOUT=600

DGX_MEM_LIMIT=80g
DGX_MEM_RESERVATION=60g
DGX_TRAIN_TIMEOUT=600

NAUTO_ORCH_MEM_LIMIT=40g
NAUTO_ORCH_MEM_RESERVATION=30g

NAUTO_WORKER_MEM_LIMIT=80g
NAUTO_WORKER_MEM_RESERVATION=60g

GEMINI_MEM_LIMIT=8g
GEMINI_MEM_RESERVATION=4g

AUTOKERNEL_MEM_LIMIT=70g
AUTOKERNEL_MEM_RESERVATION=50g
AUTOKERNEL_STAGE=profile
AUTOKERNEL_PROFILE_ARGS=
AUTOKERNEL_EXTRACT_ARGS=
AUTOKERNEL_BENCH_ARGS=
AUTOKERNEL_VERIFY_ARGS=
