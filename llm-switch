#!/usr/bin/env bash
# llm-switch — model roster for DGX Spark GB10
# usage: llm-switch [coder|architect|gemma|vision|imagine|gptoss|both|off|status]

set -euo pipefail

declare -A SVCS=(
  [coder]="qwen27-mtp.service"
  [architect]="qwen35-mtp.service"
  [gemma]="gemma-31b.service"
  [vision]="gemma-vision.service"
  [imagine]="flux-klein.service"
  [gptoss]="gptoss-20b.service"
)
declare -A PORTS=(
  [coder]=8152 [architect]=8154 [gemma]=8156
  [vision]=8155 [imagine]=8160 [gptoss]=8157
)
declare -A ROLES=(
  [coder]="qwen3.6-27B    fast coding, MTP 70%+"
  [architect]="qwen3.6-35B    deep reasoning, MoE"
  [gemma]="gemma4-31B     alt reasoning + image input"
  [vision]="gemma4-E4B     fast vision + audio input"
  [imagine]="flux.2-klein   image generation"
  [gptoss]="gpt-oss-20B    fast general, OpenAI style"
)
WAIT_TIMEOUT=300

wait_ready() {
  local slot=$1 port=${PORTS[$1]} elapsed=0
  echo -n "  waiting for $slot on :$port"
  while ! curl -sf http://127.0.0.1:$port/health > /dev/null 2>&1 && ! curl -sf http://127.0.0.1:$port/sdcpp/v1/capabilities > /dev/null 2>&1; do
    sleep 2; elapsed=$((elapsed+2)); echo -n "."
    [ $elapsed -ge $WAIT_TIMEOUT ] && { echo " TIMEOUT"; exit 1; }
  done
  echo " ready (${elapsed}s)"
}

svc_running() { systemctl --user is-active "$1" > /dev/null 2>&1; }

stop_all_except() {
  local keep="$1"
  for slot in "${!SVCS[@]}"; do
    local svc="${SVCS[$slot]}"
    if [ "$svc" != "$keep" ] && svc_running "$svc"; then
      echo "  stopping $slot..."
      systemctl --user stop "$svc"
    fi
  done
  sleep 3
}

show_status() {
  echo ""
  printf "  %-10s %-28s %-10s %s\n" "slot" "service" "state" "role"
  printf "  %-10s %-28s %-10s %s\n" "──────────" "──────────────────────────" "─────────" "──────────────────────────────"
  for slot in coder architect gemma vision imagine gptoss; do
    local svc="${SVCS[$slot]}"
    local port="${PORTS[$slot]}"
    local state=$(systemctl --user is-active "$svc" 2>/dev/null || echo "inactive")
    printf "  %-10s %-28s %-10s %s\n" "$slot" "$svc (:$port)" "$state" "${ROLES[$slot]}"
  done
  echo ""
  free -h | awk '/Mem:/{printf "  memory: %s used / %s total / %s available\n", $3, $2, $7}'
  echo ""
}

CMD="${1:-status}"

case "$CMD" in
  coder|architect|gemma|vision|imagine|gptoss)
    local_svc="${SVCS[$CMD]}"
    echo "→ $CMD mode (${ROLES[$CMD]})"
    stop_all_except "$local_svc"
    if ! svc_running "$local_svc"; then
      systemctl --user start "$local_svc"
      wait_ready "$CMD"
    else
      echo "  already running"
    fi
    show_status
    ;;
  both)
    echo "→ coder + architect"
    for slot in coder architect; do
      if ! svc_running "${SVCS[$slot]}"; then
        systemctl --user start "${SVCS[$slot]}"
        wait_ready "$slot"
      fi
    done
    show_status
    ;;
  off)
    echo "→ stopping all"
    for slot in "${!SVCS[@]}"; do
      systemctl --user stop "${SVCS[$slot]}" 2>/dev/null || true
    done
    sleep 3; show_status
    ;;
  status)
    show_status
    ;;
  *)
    echo "usage: llm-switch [coder|architect|gemma|vision|imagine|gptoss|both|off|status]"
    exit 1
    ;;
esac
