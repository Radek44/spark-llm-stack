#!/usr/bin/env bash
# flux-gen — quick image generation from CLI
# Usage: flux-gen "prompt" [width] [height] [steps] [seed]
# Example: flux-gen "pixel art sword icon, white background" 512 512 4 42

PROMPT="${1:-a beautiful landscape}"
WIDTH="${2:-512}"
HEIGHT="${3:-512}"
STEPS="${4:-4}"
SEED="${5:--1}"
BASE="${FLUX_HOST:-http://127.0.0.1:8160}"
OUTDIR="$HOME/flux-output"
mkdir -p "$OUTDIR"

# Check server
curl -sf "$BASE/sdcpp/v1/capabilities" > /dev/null 2>&1 || {
  echo "FLUX server not running — start with: llm-switch imagine"
  exit 1
}

echo "Generating: $PROMPT"
echo "Size: ${WIDTH}x${HEIGHT}  Steps: $STEPS  Seed: $SEED"

# Pass values via argv so prompts containing quotes/newlines aren't interpolated
# into Python source. Numeric values are parsed and bounds-checked in Python.
python3 - "$BASE" "$PROMPT" "$WIDTH" "$HEIGHT" "$STEPS" "$SEED" "$OUTDIR" <<'PYEOF'
import sys, time, base64
import requests

base, prompt, width_s, height_s, steps_s, seed_s, outdir = sys.argv[1:8]

def parse_int(name, value, lo, hi):
    try:
        n = int(value)
    except ValueError:
        sys.exit(f"flux-gen: {name} must be an integer, got {value!r}")
    if not (lo <= n <= hi):
        sys.exit(f"flux-gen: {name}={n} out of range [{lo}, {hi}]")
    return n

width  = parse_int("width",  width_s,  64, 4096)
height = parse_int("height", height_s, 64, 4096)
steps  = parse_int("steps",  steps_s,   1, 200)
# seed may be -1 (random) or any non-negative int
seed   = parse_int("seed",   seed_s,   -1, 2**31 - 1)

payload = {
    "prompt": prompt,
    "width": width,
    "height": height,
    "batch_count": 1,
    "seed": seed,
    "sample_params": {
        "sample_steps": steps,
        "sample_method": "euler",
        "guidance": {"txt_cfg": 1.0, "distilled_guidance": 3.5},
    },
}

r = requests.post(f"{base}/sdcpp/v1/img_gen", json=payload)
job = r.json()
job_id = job["id"]
print(f"Job: {job_id}")

start = time.time()
while True:
    time.sleep(0.5)
    r = requests.get(f"{base}/sdcpp/v1/jobs/{job_id}")
    job = r.json()
    status = job.get("status")
    if status in ("completed", "failed", "cancelled"):
        break

elapsed = time.time() - start
if status == "completed":
    images = job.get("result", {}).get("images", [])
    if images:
        img = base64.b64decode(images[0]["b64_json"])
        fname = f"{outdir}/flux-{int(time.time())}.png"
        with open(fname, "wb") as f:
            f.write(img)
        print(f"Done in {elapsed:.1f}s — {fname}  ({len(img)/1024:.0f}KB)")
    else:
        print("No images:", job.get("result"))
else:
    print(f"Failed: {job.get('error')}")
PYEOF
