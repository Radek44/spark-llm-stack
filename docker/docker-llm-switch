#!/usr/bin/env bash
# docker-llm-switch — Docker-native equivalent of llm-switch.
# Same UX, but manages spark-llm-stack containers instead of systemd user units.
#
# Runtime commands:
#   docker-llm-switch [coder|architect|gemma|vision|gptoss|imagine|comfyui]
#   docker-llm-switch off
#   docker-llm-switch status
#
# Boot-state commands (Docker analogue):
#   docker-llm-switch boot-safe              remove --restart from all slots
#   docker-llm-switch boot-default <slot>    set ONE slot to start at Docker daemon boot
#   docker-llm-switch boot-status            show which slot will auto-start at boot
#
# Mutual exclusion: starting a slot stops every other spark-llm-* container first,
# mirroring the systemd Conflicts= drop-ins from the POSTMORTEM hardening.
#
# Not covered here: imagine (FLUX) and comfyui — those need separate images
# (stable-diffusion.cpp and ComfyUI respectively, not built into spark-llm-stack).

set -euo pipefail

MODELS_DIR="${MODELS_DIR:-$HOME/models}"
COMFY_DIR="${COMFY_DIR:-$HOME/comfyui}"
PREFIX="spark-llm-"
WAIT_TIMEOUT=300

SLOTS=(coder architect gemma vision gptoss imagine comfyui)

declare -A PORTS=(
  [coder]=8152 [architect]=8154 [gemma]=8156 [vision]=8155 [gptoss]=8157
  [imagine]=8160 [comfyui]=8188
)
declare -A ROLES=(
  [coder]="qwen3.6-27B    fast coding, MTP 70%+"
  [architect]="qwen3.6-35B    deep reasoning, MoE"
  [gemma]="gemma4-31B     alt reasoning + image input"
  [vision]="gemma4-E4B     fast vision + audio input"
  [gptoss]="gpt-oss-20B    fast general, OpenAI style"
  [imagine]="flux.2-klein  image generation (sd-server)"
  [comfyui]="ComfyUI       diffusion UI + workflows"
)
declare -A MEMCAP=(
  [coder]=80g [architect]=80g [gemma]=80g [vision]=20g [gptoss]=40g
  [imagine]=16g [comfyui]=40g
)
declare -A MEMSOFT=(
  [coder]=70g [architect]=70g [gemma]=70g [vision]=15g [gptoss]=30g
  [imagine]=12g [comfyui]=30g
)
# Per-slot image. Llama slots all share one image (different CMD per slot);
# imagine and comfyui get their own images built from docker/sd-server and
# docker/comfyui respectively. Override individually via SPARK_IMAGE_<slot>.
declare -A IMAGE=(
  [coder]="${SPARK_IMAGE:-spark-llm-stack}"
  [architect]="${SPARK_IMAGE:-spark-llm-stack}"
  [gemma]="${SPARK_IMAGE:-spark-llm-stack}"
  [vision]="${SPARK_IMAGE:-spark-llm-stack}"
  [gptoss]="${SPARK_IMAGE:-spark-llm-stack}"
  [imagine]="${SPARK_IMAGE_IMAGINE:-spark-llm-imagine}"
  [comfyui]="${SPARK_IMAGE_COMFYUI:-spark-llm-comfyui}"
)

# ── slot CMD args (mirror the *.service ExecStart, with --host 0.0.0.0) ───────

