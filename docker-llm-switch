#!/usr/bin/env bash
# docker-llm-switch — Docker-native equivalent of llm-switch.
# Same UX, but manages spark-llm-stack containers instead of systemd user units.
#
# Runtime commands:
#   docker-llm-switch [coder|architect|gemma|vision|gptoss]
#   docker-llm-switch off
#   docker-llm-switch status
#
# Boot-state commands (Docker analogue):
#   docker-llm-switch boot-safe              remove --restart from all slots
#   docker-llm-switch boot-default <slot>    set ONE slot to start at Docker daemon boot
#   docker-llm-switch boot-status            show which slot will auto-start at boot
#
# Mutual exclusion: starting a slot stops every other spark-llm-* container first,
# mirroring the systemd Conflicts= drop-ins from the POSTMORTEM hardening.
#
# Not covered here: imagine (FLUX) and comfyui — those need separate images
# (stable-diffusion.cpp and ComfyUI respectively, not built into spark-llm-stack).

set -euo pipefail

IMAGE="${SPARK_IMAGE:-spark-llm-stack}"
MODELS_DIR="${MODELS_DIR:-$HOME/models}"
PREFIX="spark-llm-"
WAIT_TIMEOUT=300

SLOTS=(coder architect gemma vision gptoss)

declare -A PORTS=(
  [coder]=8152 [architect]=8154 [gemma]=8156 [vision]=8155 [gptoss]=8157
)
declare -A ROLES=(
  [coder]="qwen3.6-27B    fast coding, MTP 70%+"
  [architect]="qwen3.6-35B    deep reasoning, MoE"
  [gemma]="gemma4-31B     alt reasoning + image input"
  [vision]="gemma4-E4B     fast vision + audio input"
  [gptoss]="gpt-oss-20B    fast general, OpenAI style"
)
declare -A MEMCAP=(
  [coder]=80g [architect]=80g [gemma]=80g [vision]=20g [gptoss]=40g
)
declare -A MEMSOFT=(
  [coder]=70g [architect]=70g [gemma]=70g [vision]=15g [gptoss]=30g
)

# ── slot CMD args (mirror the *.service ExecStart, with --host 0.0.0.0) ───────

CMD_coder=(
  -m /models/Qwen3.6-27B-MTP-UD-Q4_K_XL.gguf
  --alias qwen3.6-27b-coder
  --host 0.0.0.0 --port 8152
  -ngl 999 -fa on -c 131072
  --cache-type-k q8_0 --cache-type-v q8_0 --kv-unified
  --cache-ram 49152 --cache-idle-slots
  --ctx-checkpoints 128 --cache-reuse 1024
  -b 32768 -ub 8192 --parallel 1
  --threads 8 --threads-batch 16 --threads-http 4
  --prio 3 --poll 100
  --spec-type draft-mtp
  --spec-draft-n-max 5 --spec-draft-n-min 1 --spec-draft-p-min 0.75
  --reasoning off --jinja
  --temp 0.6 --top-k 20 --top-p 0.95 --min-p 0.0
  --presence-penalty 0.0 --keep -1 --metrics --slots
)

CMD_architect=(
  -m /models/Qwen3.6-35B-A3B-MTP-Q4_K_XL.gguf
  --alias qwen3.6-35b-architect
  --host 0.0.0.0 --port 8154
  -ngl 999 -fa on -c 131072
  --cache-type-k q8_0 --cache-type-v q8_0 --kv-unified
  --cache-ram 49152 --cache-idle-slots
  --ctx-checkpoints 64 --cache-reuse 1024
  -b 16384 -ub 4096 --parallel 1
  --threads 8 --cpu-range 0-9
  --threads-batch 16 --cpu-range-batch 10-19
  --threads-http 4 --prio 2 --poll 50
  --reasoning on --reasoning-budget 4000 --reasoning-format deepseek
  --jinja
  --temp 1.0 --top-k 20 --top-p 0.95 --min-p 0.0
  --presence-penalty 0.5 --keep -1 --metrics --slots
)

CMD_gemma=(
  -m /models/gemma-4-31B-it-UD-Q4_K_XL.gguf
  --alias gemma4-31b
  --host 0.0.0.0 --port 8156
  -ngl 999 -fa on -c 131072
  --cache-type-k q8_0 --cache-type-v q8_0 --kv-unified
  --cache-ram 49152 --cache-idle-slots
  --ctx-checkpoints 64 --cache-reuse 1024
  -b 16384 -ub 4096 --parallel 1
  --threads 8 --cpu-range 0-9
  --threads-batch 16 --cpu-range-batch 10-19
  --threads-http 4 --prio 2 --poll 50
  --reasoning on --reasoning-budget 4000 --reasoning-format deepseek
  --jinja
  --temp 1.0 --top-k 64 --top-p 0.95 --min-p 0.0
  --presence-penalty 0.0 --keep -1 --metrics --slots
)

CMD_vision=(
  -m /models/gemma-4-E4B-it-UD-Q4_K_XL.gguf
  --alias gemma4-vision
  --host 0.0.0.0 --port 8155
  -ngl 999 -fa on -c 131072
  --cache-type-k q8_0 --cache-type-v q8_0 --kv-unified
  --cache-ram 8192 --cache-reuse 256
  -b 8192 -ub 2048 --parallel 1
  --threads 8 --cpu-range 0-9
  --threads-batch 10 --cpu-range-batch 10-19
  --threads-http 4 --prio 2 --poll 50
  --reasoning off --jinja
  --temp 1.0 --top-k 64 --top-p 0.95 --min-p 0.0
  --keep -1 --metrics --slots
)

CMD_gptoss=(
  --gpt-oss-20b-default
  --alias gpt-oss-20b
  --host 0.0.0.0 --port 8157
  -ngl 999 -fa on -c 131072
  --cache-type-k q8_0 --cache-type-v q8_0 --kv-unified
  --cache-ram 16384 --cache-idle-slots --cache-reuse 512
  -b 16384 -ub 4096 --parallel 1
  --threads 8 --cpu-range 0-9
  --threads-batch 16 --cpu-range-batch 10-19
  --threads-http 4 --prio 2 --poll 50
  --jinja
  --temp 0.7 --top-k 40 --top-p 0.95 --min-p 0.0
  --keep -1 --metrics --slots
)

# ── helpers ───────────────────────────────────────────────────────────────────

ctr_name() { echo "${PREFIX}$1"; }

ctr_state() {
  # running | exited | absent
  local name="$1"
  if docker ps --format '{{.Names}}' | grep -qx "$name"; then
    echo running
  elif docker ps -a --format '{{.Names}}' | grep -qx "$name"; then
    echo exited
  else
    echo absent
  fi
}

ctr_restart_policy() {
  docker inspect --format '{{.HostConfig.RestartPolicy.Name}}' "$1" 2>/dev/null || echo ""
}

stop_all_except() {
  local keep="$1"
  for slot in "${SLOTS[@]}"; do
    local name; name=$(ctr_name "$slot")
    [ "$name" = "$keep" ] && continue
    if [ "$(ctr_state "$name")" = "running" ]; then
      echo "  stopping $slot..."
      docker stop "$name" >/dev/null
    fi
  done
}

wait_ready() {
  local slot="$1" port="${PORTS[$1]}" elapsed=0
  local name; name=$(ctr_name "$slot")
  echo -n "  waiting for $slot on :$port"
  while ! curl -sf "http://127.0.0.1:$port/health" >/dev/null 2>&1; do
    if [ "$(ctr_state "$name")" != "running" ]; then
      echo " FAILED (container exited)"; exit 1
    fi
    sleep 2; elapsed=$((elapsed+2)); echo -n "."
    [ $elapsed -ge $WAIT_TIMEOUT ] && { echo " TIMEOUT"; exit 1; }
  done
  echo " ready (${elapsed}s)"
}

# Shared `docker run` for a slot. Caller passes lifecycle flags as
# extra args (e.g. `--rm` for runtime, `--restart on-failure:3` for boot-default).
docker_run_slot() {
  local slot="$1"; shift
  local name; name=$(ctr_name "$slot")
  local mem="${MEMCAP[$slot]}"
  local memsoft="${MEMSOFT[$slot]}"
  declare -n cmd_ref="CMD_${slot}"
  docker run -d --name "$name" "$@" \
    --gpus=all --network=host \
    --memory="$mem" --memory-swap="$mem" \
    --memory-reservation="$memsoft" \
    --ulimit memlock=-1:-1 \
    --shm-size=1g \
    -v "${MODELS_DIR}:/models" \
    -e "HUGGING_FACE_HUB_TOKEN=${HUGGING_FACE_HUB_TOKEN:-}" \
    "${IMAGE}" \
    "${cmd_ref[@]}" >/dev/null
}

run_slot() {
  local slot="$1"
  local name; name=$(ctr_name "$slot")

  # If an old (stopped) container exists with the same name, remove it.
  if [ "$(ctr_state "$name")" = "exited" ]; then
    docker rm "$name" >/dev/null
  fi

  # Runtime mode: --rm so an OOM-killed container is removed, not respawned
  # (Docker analogue of OOMPolicy=stop from the POSTMORTEM hardening).
  docker_run_slot "$slot" --rm
}

show_status() {
  echo ""
  printf "  %-10s %-22s %-10s %-9s %s\n" "slot" "container" "state" "at-boot" "role"
  printf "  %-10s %-22s %-10s %-9s %s\n" "──────────" "────────────────────" "─────────" "─────────" "──────────────────────────"
  for slot in "${SLOTS[@]}"; do
    local name; name=$(ctr_name "$slot")
    local port="${PORTS[$slot]}"
    local state boot
    state=$(ctr_state "$name")
    boot=$(ctr_restart_policy "$name")
    [ "$boot" = "on-failure" ] && boot="enabled" || boot="disabled"
    [ "$state" = "absent" ] && boot="-"
    printf "  %-10s %-22s %-10s %-9s %s\n" \
      "$slot" "$name (:$port)" "$state" "$boot" "${ROLES[$slot]}"
  done
  echo ""
  free -h 2>/dev/null | awk '/Mem:/{printf "  memory: %s used / %s total / %s available\n", $3, $2, $7}'
  echo ""
}

boot_safe() {
  echo "→ removing --restart policy from all spark-llm-* containers"
  for slot in "${SLOTS[@]}"; do
    local name; name=$(ctr_name "$slot")
    if [ "$(ctr_state "$name")" != "absent" ]; then
      docker update --restart no "$name" >/dev/null 2>&1 || true
      echo "  $slot: restart policy cleared"
    fi
  done
  boot_status
}

boot_default() {
  local slot="$1"
  if [ -z "${PORTS[$slot]:-}" ]; then
    echo "unknown slot: $slot" >&2
    echo "valid: ${SLOTS[*]}" >&2
    exit 1
  fi
  local keep; keep=$(ctr_name "$slot")
  echo "→ setting $slot as Docker boot-default (clears restart policy on others)"
  echo "  using --restart on-failure:3 (matches StartLimitBurst=3 + OOMPolicy=stop"
  echo "  from POSTMORTEM hardening — prevents OOM respawn brick loop)"

  for s in "${SLOTS[@]}"; do
    local name; name=$(ctr_name "$s")
    if [ "$name" = "$keep" ]; then
      case "$(ctr_state "$name")" in
        absent|exited)
          [ "$(ctr_state "$name")" = "exited" ] && docker rm "$name" >/dev/null
          docker_run_slot "$slot" --restart on-failure:3
          echo "  $s: created with --restart on-failure:3"
          ;;
        running)
          # Running containers were started by run_slot with --rm, so
          # `docker update --restart` would fail. Stop and recreate without
          # --rm so the on-failure:3 policy actually applies at next boot.
          echo "  $s: already running with --rm; recreating with --restart on-failure:3"
          docker stop "$name" >/dev/null
          [ "$(ctr_state "$name")" = "exited" ] && docker rm "$name" >/dev/null 2>&1 || true
          docker_run_slot "$slot" --restart on-failure:3
          ;;
      esac
    else
      if [ "$(ctr_state "$name")" != "absent" ]; then
        docker update --restart no "$name" >/dev/null 2>&1 || true
        echo "  $s: restart policy cleared"
      fi
    fi
  done
  boot_status
}

boot_status() {
  echo ""
  local any=0
  for slot in "${SLOTS[@]}"; do
    local name; name=$(ctr_name "$slot")
    if [ "$(ctr_restart_policy "$name")" = "on-failure" ]; then
      printf "  auto-start at Docker boot: %s (%s)\n" "$slot" "$name"
      any=1
    fi
  done
  if [ "$any" = "0" ]; then
    echo "  no slot will auto-start at Docker daemon boot."
  fi
  echo ""
}

# ── dispatcher ────────────────────────────────────────────────────────────────

CMD="${1:-status}"

case "$CMD" in
  coder|architect|gemma|vision|gptoss)
    target=$(ctr_name "$CMD")
    echo "→ $CMD mode (${ROLES[$CMD]})"
    stop_all_except "$target"
    if [ "$(ctr_state "$target")" = "running" ]; then
      echo "  already running"
    else
      run_slot "$CMD"
      wait_ready "$CMD"
    fi
    show_status
    ;;
  off)
    echo "→ stopping all spark-llm-* containers"
    for slot in "${SLOTS[@]}"; do
      name=$(ctr_name "$slot")
      [ "$(ctr_state "$name")" = "running" ] && docker stop "$name" >/dev/null && echo "  stopped $slot"
    done
    show_status
    ;;
  status)
    show_status
    ;;
  boot-safe)
    boot_safe
    ;;
  boot-default)
    if [ -z "${2:-}" ]; then
      echo "usage: docker-llm-switch boot-default <slot>" >&2
      echo "valid slots: ${SLOTS[*]}" >&2
      exit 1
    fi
    boot_default "$2"
    ;;
  boot-status)
    boot_status
    ;;
  -h|--help|help)
    cat <<EOF
docker-llm-switch — Docker-native llm-switch for DGX Spark GB10

Runtime:
  docker-llm-switch <slot>          start one slot (stops all others)
  docker-llm-switch off             stop everything
  docker-llm-switch status          show current state

Boot (Docker daemon restart policy):
  docker-llm-switch boot-safe       clear --restart on all slots
  docker-llm-switch boot-default <slot>
                                    set ONE slot to --restart unless-stopped
  docker-llm-switch boot-status     show what auto-starts at Docker boot

Slots: ${SLOTS[*]}

Env overrides:
  SPARK_IMAGE  (default: spark-llm-stack)
  MODELS_DIR   (default: \$HOME/models)
EOF
    ;;
  *)
    echo "unknown command: $CMD" >&2
    echo "run 'docker-llm-switch help' for usage" >&2
    exit 1
    ;;
esac
