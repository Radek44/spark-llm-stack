# Threading (--threads 16 / --threads-batch 16) — see
# docs/architecture/DECISIONS.md §10. Vision keeps --parallel 1 for
# interactive latency.

[Unit]
Description=Gemma4 E4B Vision on 8155
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment="CUDA_SCALE_LAUNCH_QUEUES=4x"
Environment="GGML_CUDA_GRAPH_OPT=1"
Environment="GGML_CUDA_FORCE_CUBLAS_COMPUTE_16F=1"

ExecStart=/home/radek/src/llama.cpp-mtp/build/bin/llama-server \
  -hf unsloth/gemma-4-E4B-it-GGUF:UD-Q4_K_XL \
  --alias gemma4-vision \
  --host 127.0.0.1 \
  --port 8155 \
  -ngl 999 \
  -fa on \
  -c 131072 \
  --cache-type-k q8_0 \
  --cache-type-v q8_0 \
  --kv-unified \
  --cache-ram 8192 \
  --cache-reuse 256 \
  -b 8192 \
  -ub 2048 \
  --parallel 1 \
  --threads 16 \
  --threads-batch 16 \
  --threads-http 4 \
  --prio 2 \
  --poll 50 \
  --reasoning off \
  --jinja \
  --temp 1.0 \
  --top-k 64 \
  --top-p 0.95 \
  --min-p 0.0 \
  --keep -1 \
  --metrics \
  --slots

Restart=on-failure
RestartSec=5
LimitNOFILE=1048576

[Install]
WantedBy=default.target
