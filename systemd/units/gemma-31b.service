# Threading (--threads 16 / --threads-batch 24) and the absence of --parallel
# >1 are explained in docs/architecture/DECISIONS.md §10 + §11.

[Unit]
Description=Gemma4 31B Alt Architect on 8156
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment="CUDA_SCALE_LAUNCH_QUEUES=4x"
Environment="GGML_CUDA_GRAPH_OPT=1"
Environment="GGML_CUDA_FORCE_CUBLAS_COMPUTE_16F=1"

ExecStart=/home/radek/src/llama.cpp-mtp/build/bin/llama-server \
  -hf unsloth/gemma-4-31B-it-GGUF:UD-Q4_K_XL \
  --alias gemma4-31b \
  --host 127.0.0.1 \
  --port 8156 \
  -ngl 999 \
  -fa on \
  -c 131072 \
  --cache-type-k q8_0 \
  --cache-type-v q8_0 \
  --kv-unified \
  --cache-ram 49152 \
  --cache-idle-slots \
  --ctx-checkpoints 64 \
  --cache-reuse 1024 \
  -b 16384 \
  -ub 4096 \
  --parallel 1 \
  --threads 16 \
  --threads-batch 24 \
  --threads-http 4 \
  --prio 2 \
  --poll 50 \
  --reasoning on \
  --reasoning-budget 4000 \
  --reasoning-format deepseek \
  --jinja \
  --temp 1.0 \
  --top-k 64 \
  --top-p 0.95 \
  --min-p 0.0 \
  --presence-penalty 0.0 \
  --keep -1 \
  --metrics \
  --slots

Restart=on-failure
RestartSec=5
LimitNOFILE=1048576

[Install]
WantedBy=default.target
